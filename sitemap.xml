---
permalink: /sitemap.xml
# No layout — Jekyll still processes the Liquid below because of this front matter.
# Gated to production like _includes/google-analytics.html — local `jekyll serve` emits an empty file (no localhost URLs).
---
{%- if jekyll.environment == "production" -%}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- assign pages = site.html_pages | where_exp: "p", "p.sitemap != false" -%}
{%- for page in pages -%}
{%- if page.url == "/404.html" -%}{%- continue -%}{%- endif -%}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
    {%- if page.last_modified_at %}
    <lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>
    {%- elsif page.date %}
    <lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
    {%- elsif page.last_edit %}
    {%- comment %} last_edit is a display string "DD/MM/YYYY - HH:MM AM/PM"; reorder to YYYY-MM-DD (date-only lastmod is valid). {%- endcomment %}
    {%- assign _dmy = page.last_edit | split: " - " | first | split: "/" %}
    {%- if _dmy.size == 3 %}
    <lastmod>{{ _dmy[2] }}-{{ _dmy[1] }}-{{ _dmy[0] }}</lastmod>
    {%- endif %}
    {%- endif %}
  </url>
{%- endfor -%}
{%- for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
{%- endfor %}
</urlset>
{%- endif -%}
